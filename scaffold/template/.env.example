# ─── Secrets & Environment Overrides ─────────────────────────────────────────
# All configuration lives in app/settings.toml.
# Any [section].field can be overridden via SECTION_FIELD env var.
# This file is for secrets and per-deployment overrides only.

APP_ENV=local
APP_KEY={{APP_KEY}}
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/{{PROJECT_NAME}}
REDIS_URL=redis://127.0.0.1:6379/0
VITE_REALTIME_PORT=3010
S3_ACCESS_KEY=
S3_SECRET_KEY=
MAIL_USERNAME=
MAIL_PASSWORD=

# Standard Rust logging (read directly by tracing, not in settings.toml)
RUST_LOG=info

# ─── Deployment ───────────────────────────────────────────────────────────────
# Used by scripts/deploy-poll.sh and scripts/deploy-docker.sh
DEPLOY_ENV=staging
S3_ENDPOINT=
S3_BUCKET=

# Used by scripts/install-ubuntu.sh
PROJECT_USER=
SUPERVISOR_PROJECT_SLUG=
